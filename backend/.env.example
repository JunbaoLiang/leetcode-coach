# Anthropic API key (backend only — the frontend must never call Anthropic directly)
ANTHROPIC_API_KEY=sk-ant-...

# SQLite for local dev (default if unset); switch to PostgreSQL in production
DATABASE_URL=sqlite:///./data/app.db

# --- Multi-user mode (production) ------------------------------------------
# Local dev keeps AUTH_ENABLED=false: single user, no login required.
AUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=            # long random string, e.g. `openssl rand -hex 32`
# public app origin for the OAuth redirect (e.g. https://your-app.vercel.app)
PUBLIC_BASE_URL=
